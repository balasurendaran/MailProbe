# Server Configuration
PORT=3000
NODE_ENV=development

# API Key Authentication (optional - leave empty to disable)
# If set, clients must pass this in the X-API-Key header
API_KEY=your_secret_api_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000       # 1 minute window
RATE_LIMIT_MAX_REQUESTS=30       # max requests per window per IP

# SMTP Check Configuration
SMTP_TIMEOUT_MS=5000             # timeout for SMTP connection (ms)
SMTP_FROM_EMAIL=verify@yourdomain.com  # sender used in EHLO/MAIL FROM

# CORS - comma-separated list of allowed origins (* for all)
ALLOWED_ORIGINS=*
